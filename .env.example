# Tasmota-OpenBK-MCP Configuration
# Copy this file to .env and fill in your values

# --- Network scanning range ---
# Define the IP range for device discovery
START_IP=192.168.0.1
END_IP=192.168.0.254

# Optional: CIDR range (overrides START_IP/END_IP if set)
# NETWORK_RANGE=192.168.0.0/24

# --- MQTT broker connection ---
MQTT_BROKER=192.168.0.101
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# --- Server ports (defaults shown) ---
HEALTH_CHECK_PORT=9100
MCP_SSE_PORT=9101
REST_API_PORT=9102

# --- Logging (optional) ---
# LOG_LEVEL=INFO

# --- Write guard ---
# Server-level authorization gate for write/destructive tools (set_power,
# set_brightness, restart_device, mqtt_publish). Disabled by default — these
# tools return a WRITE_DISABLED error before any I/O until this is set to 1.
ENABLE_WRITE_OPERATIONS=0

# --- Server bind (default: 127.0.0.1) ---
# For Docker with --network host, set BIND_HOST=0.0.0.0 and MCP_UNSAFE_PUBLIC_ACCESS_CONFIRMED=1
BIND_HOST=127.0.0.1
# MCP_UNSAFE_PUBLIC_ACCESS_CONFIRMED=1
# Codecov upload — get your token at https://app.codecov.io
CODECOV_TOKEN=your_codecov_token_here
