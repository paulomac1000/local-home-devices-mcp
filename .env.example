# Local Home Devices MCP Configuration
# Copy this file to .env and fill in your values

# --- Network scanning range ---
# Define the IP range for device discovery
START_IP=192.168.1.1
END_IP=192.168.1.254

# Optional: CIDR range (overrides START_IP/END_IP if set)
# NETWORK_RANGE=192.168.1.0/24

# --- MQTT broker connection ---
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# --- Hikvision Doorbell (DS-KV6113-WPE1(C)) ---
# ISAPI HTTP Digest Auth credentials for a video doorbell.
HIKVISION_DOORBELL_HOST=192.168.1.101
HIKVISION_DOORBELL_USER=doorbell_user
HIKVISION_DOORBELL_PASSWORD=your_doorbell_password
HIKVISION_CONTAINER_NAME=hikvision-doorbell
DOCKER_SOCKET=/var/run/docker.sock

# --- OpenHASP panel defaults ---
OPENHASP_DEFAULT_HOST=192.168.1.100
OPENHASP_HTTP_PORT=80
OPENHASP_TELNET_PORT=23
OPENHASP_TIMEOUT=10
OPENHASP_TELNET_TIMEOUT=5

# --- Tuya Cloud API credentials ---
# From: https://iot.tuya.com -> Cloud -> Projects -> Edit -> Authorization Key
TUYA_ACCESS_ID=your_access_id_here
TUYA_ACCESS_SECRET=your_access_secret_here
TUYA_PROJECT_CODE=your_project_code_here

# --- Tuya Local Device Cache ---
TUYA_DEVICES_FILE=data/tuya_devices.json

# --- Server ports (defaults shown) ---
HEALTH_CHECK_PORT=9100
MCP_SSE_PORT=9101
REST_API_PORT=9102

# --- Logging (optional) ---
# LOG_LEVEL=INFO

# --- Write guard ---
# Server-level authorization gate for write/destructive tools (set_power,
# set_brightness, restart_device, mqtt_publish). Disabled by default - these
# tools return a WRITE_DISABLED error before any I/O until this is set to 1.
ENABLE_WRITE_OPERATIONS=0

# --- Server bind (default: 127.0.0.1) ---
# For Docker with --network host, set BIND_HOST=0.0.0.0 and MCP_UNSAFE_PUBLIC_ACCESS_CONFIRMED=1
BIND_HOST=127.0.0.1
# MCP_UNSAFE_PUBLIC_ACCESS_CONFIRMED=1
# Codecov upload - get your token at https://app.codecov.io
CODECOV_TOKEN=your_codecov_token_here
